{
  "name": "pyth-relayer",
  "version": "1.0.0",
  "description": "Production Pyth Network relayer for Stellar Soroban",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "dev:server": "nodemon src/server.ts",
    "dev:relayer": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "start:relayer": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "pyth",
    "stellar",
    "soroban",
    "oracle",
    "relayer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@pythnetwork/hermes-client": "^3.1.0",
    "@stellar/stellar-sdk": "^14.4.3",
    "express": "^4.19.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
